#!/bin/bash
# Claude Code with 通义千问 (OpenAI 兼容)
# 参考文档: https://bailian.console.aliyun.com/cn-beijing/?tab=doc#/doc/?type=model&url=2949529

# 从 API_KEYS.md 读取配置
WORKSPACE_DIR="$(cd "$(dirname "$0")" && pwd)"
API_KEYS_FILE="/home/node/.openclaw/workspace/API_KEYS.md"

if [ -f "$API_KEYS_FILE" ]; then
    # 提取 API Key
    OPENAI_API_KEY=$(grep -A 5 "## 阿里云百炼大模型" "$API_KEYS_FILE" | grep "API Key" | sed 's/.*`\([^`]*\)`.*/\1/')
    
    if [ -z "$OPENAI_API_KEY" ]; then
        echo "❌ 错误: 无法从 API_KEYS.md 读取 API Key"
        echo "请检查 $API_KEYS_FILE 文件是否存在且格式正确"
        exit 1
    fi
else
    echo "❌ 错误: 找不到 API_KEYS.md 文件"
    echo "请确认文件位置: $API_KEYS_FILE"
    exit 1
fi

# 百炼平台配置
export OPENAI_API_KEY
export OPENAI_BASE_URL="https://coding.dashscope.aliyuncs.com/v1"

# 使用通义千问模型
export CLAUDE_MODEL="qwen3.5-plus"

echo "🚀 Starting Claude Code with 通义千问 (Bailian)..."
echo "API Base: $OPENAI_BASE_URL"
echo "Model: $CLAUDE_MODEL"
echo ""

# 使用全局安装的 claude
exec /home/node/.local/bin/claude "$@"
